# Comma-separated origins allowed to call this API when deployed separately from frontend.
# Leave empty to allow all origins.
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:4173

# Vercel frontend build-time variable used to point app.js fetch calls to Railway backend.
# Set this in Vercel Project Settings -> Environment Variables.
GHOST_API_BASE_URL=https://your-railway-domain.up.railway.app

# JSON array of live monitored sites and pages.
# This is now the production source of Mission Control website/page telemetry.
# Example:
# [
#   {
#     "id": "ghost-ai-solutions",
#     "name": "Ghost AI Solutions",
#     "domain": "ghostai.solutions",
#     "pages": [
#       {"label": "Homepage", "url": "https://ghostai.solutions/"},
#       {"label": "Services", "url": "https://ghostai.solutions/services"}
#     ]
#   }
# ]
MONITORED_SITES=[]

# Optional quick-start alternative to MONITORED_SITES. Comma-separated URLs.
MONITORED_SITE_URLS=

# Optional request timeout for page checks in milliseconds.
PAGE_TIMEOUT_MS=8000

# Optional cache duration for mission snapshot generation in milliseconds.
MONITOR_CACHE_TTL_MS=60000

# Enable/disable automatic page discovery from sitemap.xml and robots.txt sitemap entries.
AUTO_DISCOVER_PAGES=true

# Cache duration for sitemap/page discovery results.
DISCOVERY_CACHE_TTL_MS=300000

# Maximum pages to ingest per site from sitemap discovery.
MAX_DISCOVERED_PAGES=250

# Maximum sitemap nesting depth when resolving sitemap indexes.
DISCOVERY_MAX_DEPTH=2

# Vercel project auto-import (optional)
# When enabled with VERCEL_TOKEN, backend will import Vercel projects and monitor their production URLs.
VERCEL_AUTO_IMPORT_PROJECTS=true
VERCEL_TOKEN=
# Optional team scope for Vercel API (use when projects are under a team).
VERCEL_TEAM_ID=
# Cache duration for Vercel project discovery.
VERCEL_SYNC_CACHE_TTL_MS=300000
# Max projects pulled from Vercel API per sync cycle.
VERCEL_MAX_PROJECTS=100

# AI provider orchestration (OpenAI + Anthropic + OpenRouter)
# AI_PROVIDER can be: auto, openai, anthropic, openrouter
AI_PROVIDER=auto
AI_REQUEST_TIMEOUT_MS=12000

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional but recommended for OpenRouter rankings/analytics.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=Ghost Mission Control

# GitHub repo inventory for Tool Registry, Web Helpers, and code-aware agents.
# Public repos load with only GITHUB_OWNER. Add GITHUB_TOKEN for private repos and agent inspection.
GITHUB_OWNER=burchdad
GITHUB_TOKEN=
GITHUB_REPO_CACHE_TTL_MS=300000
GITHUB_MAX_REPO_PAGES=10

# Client Admin Dashboard -> Mission Control Web Helper request intake.
# Set these on the Mission Control backend (Railway).
# The webhook endpoint should receive website update/upgrade requests from client admin dashboards
# and route them to the matching Web Helper by client/site/repo.
GHOST_WEB_HELPER_WEBHOOK_SECRET=

# Public client portal read-only access keys.
# JSON object mapping magic-link keys to Mission Control client ids.
# Example: {"gray-matters-demo":"gray-matters","keisha-portal":"keisha-law"}
CLIENT_PORTAL_ACCESS_KEYS={}
CLIENT_PORTAL_ALLOW_CLIENT_ID_KEYS=false

GHOST_WEB_HELPER_ALLOWED_SOURCES=client_admin_dashboard
GHOST_WEB_HELPER_DEFAULT_BRANCH_POLICY=testing_branch_only
GHOST_WEB_HELPER_DEFAULT_APPROVAL_REQUIRED=true
WEB_HELPER_AUTOMATION_START_DELAY_MS=8000
WEB_HELPER_TRIAGE_TO_CODEX_DELAY_MS=8000

# Web Helper -> Codex worker handoff.
# Point CODEX_BUILD_WEBHOOK_URL at this app's /mission/codex-runner/intake endpoint for the built-in runner.
CODEX_BUILD_WEBHOOK_URL=
CODEX_BUILD_WEBHOOK_SECRET=
CODEX_BUILD_DEFAULT_BASE_BRANCH=main
CODEX_BUILD_DEFAULT_TEST_COMMAND=npm run check && npm run build
# Optional: when true, intake immediately runs the worker command after creating the branch/work-order.
# When false, call POST /mission/codex-runner/work with the same payload to run the worker.
CODEX_WORKER_AUTORUN=false
# Executable used to mutate the checked-out client repo. Example: codex
CODEX_WORKER_COMMAND=
# JSON array or quoted argument string. Codex exec reads the prompt from stdin.
# Placeholders are replaced before execution:
# {PROMPT_PATH}, {REPO_DIR}, {TICKET_ID}, {TASK_ID}, {BRANCH}
# Legacy ["exec","--prompt-file","{PROMPT_PATH}"] is auto-normalized for Codex.
CODEX_WORKER_ARGS=["exec","--dangerously-bypass-approvals-and-sandbox"]
CODEX_WORKER_TIMEOUT_MS=600000
CODEX_WORKER_ROOT=
# external = push branch and wait for GitHub/Vercel checks; local = run CODEX_BUILD_DEFAULT_TEST_COMMAND in the worker; none = skip verification.
CODEX_WORKER_VERIFICATION_MODE=external
CODEX_EXTERNAL_VERIFICATION_POLL_INTERVAL_MS=30000
CODEX_EXTERNAL_VERIFICATION_MAX_ATTEMPTS=20

# Set these on each client website/admin dashboard.
# GHOST_MISSION_CONTROL_WEBHOOK_URL should point to the Mission Control backend intake endpoint.
# Example: https://your-railway-domain.up.railway.app/mission/web-helper-requests
GHOST_MISSION_CONTROL_WEBHOOK_URL=
GHOST_MISSION_CONTROL_WEBHOOK_SECRET=
GHOST_CLIENT_ID=
GHOST_CLIENT_NAME=
GHOST_SITE_URL=
GHOST_REPO=
GHOST_WEB_HELPER_ID=
GHOST_WEB_HELPER_BRANCH_POLICY=testing_branch_only
GHOST_WEB_HELPER_APPROVAL_REQUIRED=true
