# Comma-separated origins allowed to call this API when deployed separately from frontend.
# Leave empty to allow all origins.
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:4173

# Vercel frontend build-time variable used to point app.js fetch calls to Railway backend.
# Set this in Vercel Project Settings -> Environment Variables.
GHOST_API_BASE_URL=https://your-railway-domain.up.railway.app

# JSON array of live monitored sites and pages.
# This is now the production source of Mission Control website/page telemetry.
# Example:
# [
#   {
#     "id": "ghost-ai-solutions",
#     "name": "Ghost AI Solutions",
#     "domain": "ghostai.solutions",
#     "pages": [
#       {"label": "Homepage", "url": "https://ghostai.solutions/"},
#       {"label": "Services", "url": "https://ghostai.solutions/services"}
#     ]
#   }
# ]
MONITORED_SITES=[]

# Optional quick-start alternative to MONITORED_SITES. Comma-separated URLs.
MONITORED_SITE_URLS=

# Optional request timeout for page checks in milliseconds.
PAGE_TIMEOUT_MS=8000

# Optional cache duration for mission snapshot generation in milliseconds.
MONITOR_CACHE_TTL_MS=60000

# Enable/disable automatic page discovery from sitemap.xml and robots.txt sitemap entries.
AUTO_DISCOVER_PAGES=true

# Cache duration for sitemap/page discovery results.
DISCOVERY_CACHE_TTL_MS=300000

# Maximum pages to ingest per site from sitemap discovery.
MAX_DISCOVERED_PAGES=250

# Maximum sitemap nesting depth when resolving sitemap indexes.
DISCOVERY_MAX_DEPTH=2

# Vercel project auto-import (optional)
# When enabled with VERCEL_TOKEN, backend will import Vercel projects and monitor their production URLs.
VERCEL_AUTO_IMPORT_PROJECTS=true
VERCEL_TOKEN=
# Optional team scope for Vercel API (use when projects are under a team).
VERCEL_TEAM_ID=
# Cache duration for Vercel project discovery.
VERCEL_SYNC_CACHE_TTL_MS=300000
# Max projects pulled from Vercel API per sync cycle.
VERCEL_MAX_PROJECTS=100

# AI provider orchestration (OpenAI + Anthropic + OpenRouter)
# AI_PROVIDER can be: auto, openai, anthropic, openrouter
AI_PROVIDER=auto
AI_REQUEST_TIMEOUT_MS=12000

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional but recommended for OpenRouter rankings/analytics.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=Ghost Mission Control
